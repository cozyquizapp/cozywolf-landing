{
  "rewrites": [
    { "source": "/", "destination": "/app.html" },
    { "source": "/impressum", "destination": "/app.html" },
    { "source": "/datenschutz", "destination": "/app.html" },
    { "source": "/firmen", "destination": "/app.html" },
    { "source": "/locations", "destination": "/app.html" },
    { "source": "/feiern", "destination": "/app.html" },
    { "source": "/ueber", "destination": "/app.html" },
    { "source": "/kontakt", "destination": "/app.html" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/support.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
